generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPERADMIN
  ADMIN
  CAJERO
  EMPLEADO
}

enum PaymentMethod {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  QR
}

enum CashierStatus {
  ABIERTA
  CERRADA
}

enum OrderStatus {
  PENDIENTE
  PAGADO
  CANCELADO
}

enum GeneralExpenseCategory {
  SERVICIOS
  NOMINA
  MANTENIMIENTO
  SUMINISTROS
  OTRO
  COBRO_DEUDA
  PRESTAMO_RECIBIDO
  OTRO_INGRESO
}

enum PurchaseOrderStatus {
  PENDIENTE
  RECIBIDA
  CANCELADA
}

enum PayrollPeriodType {
  QUINCENAL
  MENSUAL
}

enum PayrollPeriodStatus {
  ABIERTO
  CERRADO
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tarifas de entrada (configurables por el admin del tenant)
  entryAdultPrice   Decimal @default(5000) @db.Decimal(10, 2)
  entryChildPrice   Decimal @default(4000) @db.Decimal(10, 2)
  entryFreeUnderAge Int     @default(4)

  users            User[]
  accessEntries    AccessEntry[]
  products         Product[]
  productVariants  ProductVariant[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  orders           Order[]
  sales            Sale[]
  cashierSessions  CashierSession[]
  cashExpenses     CashExpense[]
  generalExpenses  GeneralExpense[]
  employees        Employee[]
  payrollPeriods   PayrollPeriod[]

  @@index([isActive])
  @@map("tenants")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(CAJERO)
  isActive  Boolean  @default(true)
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  sessions        CashierSession[]
  generalExpenses GeneralExpense[]
  purchaseOrders  PurchaseOrder[]

  @@index([email])
  @@index([tenantId])
  @@map("users")
}

// ─── Access Control ───────────────────────────────────────────────────────────

model AccessEntry {
  id               String         @id @default(cuid())
  tenantId         String
  visitorName      String?
  pax              Int            @default(1)
  adults           Int            @default(0)
  children         Int            @default(0)
  freeMinors       Int            @default(0)
  totalAmount      Decimal        @default(0) @db.Decimal(10, 2)
  paymentMethod    PaymentMethod?
  amountPaid       Decimal?       @db.Decimal(10, 2)
  change           Decimal        @default(0) @db.Decimal(10, 2)
  cashierSessionId String?
  entryTime        DateTime       @default(now())
  exitTime         DateTime?
  notes            String?
  createdAt        DateTime       @default(now())

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  cashierSession CashierSession? @relation(fields: [cashierSessionId], references: [id])
  orders         Order[]

  @@index([tenantId])
  @@index([tenantId, entryTime])
  @@index([cashierSessionId])
  @@map("access_entries")
}

// ─── Inventario ───────────────────────────────────────────────────────────────

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("suppliers")
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  brand       String?
  description String?
  category    String
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  variants ProductVariant[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@map("products")
}

// Presentación/empaque vendible de un producto (ej. Coca-Cola 600ml, Coca-Cola 1.5L).
// El stock siempre se maneja en `saleUnit`; las compras se hacen en `purchaseUnit`
// y se convierten multiplicando por `unitsPerPurchase`.
model ProductVariant {
  id               String   @id @default(cuid())
  tenantId         String
  productId        String
  name             String
  sku              String?
  barcode          String?
  purchaseUnit     String   @default("Unidad")
  saleUnit         String   @default("Unidad")
  unitsPerPurchase Int      @default(1)
  price            Decimal  @db.Decimal(10, 2)
  cost             Decimal  @default(0) @db.Decimal(10, 2)
  stock            Int      @default(0)
  isAvailable      Boolean  @default(true)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  product            Product             @relation(fields: [productId], references: [id])
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([productId, name])
  @@index([tenantId])
  @@index([productId])
  @@index([tenantId, isAvailable])
  @@map("product_variants")
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  tenantId    String
  supplierId  String
  status      PurchaseOrderStatus @default(PENDIENTE)
  orderDate   DateTime            @default(now())
  receivedAt  DateTime?
  totalAmount Decimal             @default(0) @db.Decimal(12, 2)
  notes       String?
  createdBy   String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id])
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  user     User                @relation(fields: [createdBy], references: [id])
  items    PurchaseOrderItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  productVariantId String
  quantity        Int
  unitCost        Decimal  @db.Decimal(10, 2)
  subtotal        Decimal  @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime @default(now())

  purchaseOrder  PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

// ─── Store (POS) ──────────────────────────────────────────────────────────────

model Order {
  id            String       @id @default(cuid())
  tenantId      String
  customerName  String?
  accessEntryId String?
  status        OrderStatus  @default(PENDIENTE)
  totalAmount   Decimal      @default(0) @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  closedAt      DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  accessEntry AccessEntry? @relation(fields: [accessEntryId], references: [id])
  items       OrderItem[]
  sale        Sale?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([accessEntryId])
  @@map("orders")
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  productVariantId String
  quantity         Int
  unitPrice        Decimal  @db.Decimal(10, 2)
  subtotal         Decimal  @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime @default(now())

  order          Order          @relation(fields: [orderId], references: [id])
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Sale {
  id               String        @id @default(cuid())
  tenantId         String
  orderId          String        @unique
  cashierSessionId String
  totalAmount      Decimal       @db.Decimal(10, 2)
  paymentMethod    PaymentMethod
  amountPaid       Decimal       @db.Decimal(10, 2)
  change           Decimal       @default(0) @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime      @default(now())

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  order          Order          @relation(fields: [orderId], references: [id])
  cashierSession CashierSession @relation(fields: [cashierSessionId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([cashierSessionId])
  @@map("sales")
}

// ─── Cashier ──────────────────────────────────────────────────────────────────

model CashierSession {
  id            String        @id @default(cuid())
  tenantId      String
  userId        String
  status        CashierStatus @default(ABIERTA)
  openingAmount Decimal       @db.Decimal(10, 2)
  closingAmount Decimal?      @db.Decimal(10, 2)
  totalSales    Decimal       @default(0) @db.Decimal(10, 2)
  totalExpenses Decimal       @default(0) @db.Decimal(10, 2)
  totalIngresos Decimal       @default(0) @db.Decimal(10, 2)
  difference    Decimal?      @db.Decimal(10, 2)
  openedAt      DateTime      @default(now())
  closedAt      DateTime?
  notes         String?

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  sales         Sale[]
  cashExpenses  CashExpense[]
  accessEntries AccessEntry[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, openedAt])
  @@map("cashier_sessions")
}

model CashExpense {
  id               String   @id @default(cuid())
  tenantId         String
  cashierSessionId String
  description      String
  type             String   @default("EGRESO")
  totalAmount      Decimal  @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime @default(now())

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  cashierSession CashierSession @relation(fields: [cashierSessionId], references: [id])

  @@index([tenantId])
  @@index([cashierSessionId])
  @@map("cash_expenses")
}

// ─── Employees & Payroll ──────────────────────────────────────────────────────

model Employee {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  role         String
  baseSalary   Decimal  @db.Decimal(12, 2)
  phone        String?
  email        String?
  notes        String?
  isActive     Boolean  @default(true)
  hiredAt      DateTime @db.Date
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  payrollEntries PayrollEntry[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("employees")
}

model PayrollPeriod {
  id         String              @id @default(cuid())
  tenantId   String
  periodType PayrollPeriodType   @default(QUINCENAL)
  startDate  DateTime            @db.Date
  endDate    DateTime            @db.Date
  status     PayrollPeriodStatus @default(ABIERTO)
  notes      String?
  createdAt  DateTime            @default(now())
  closedAt   DateTime?

  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  entries PayrollEntry[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, startDate])
  @@map("payroll_periods")
}

model PayrollEntry {
  id              String   @id @default(cuid())
  payrollPeriodId String
  employeeId      String
  baseSalary      Decimal  @db.Decimal(12, 2)
  extras          Decimal  @default(0) @db.Decimal(12, 2)
  deductions      Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  isPaid          Boolean  @default(false)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payrollPeriod PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])
  employee      Employee      @relation(fields: [employeeId], references: [id])

  @@unique([payrollPeriodId, employeeId])
  @@index([payrollPeriodId])
  @@index([employeeId])
  @@map("payroll_entries")
}

// ─── General Expenses ─────────────────────────────────────────────────────────

model GeneralExpense {
  id          String                 @id @default(cuid())
  tenantId    String
  category    GeneralExpenseCategory
  description String
  type        String                 @default("EGRESO")
  amount      Decimal                @db.Decimal(12, 2)
  receiptRef  String?
  date        DateTime               @db.Date
  notes       String?
  createdBy   String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, category])
  @@map("general_expenses")
}
